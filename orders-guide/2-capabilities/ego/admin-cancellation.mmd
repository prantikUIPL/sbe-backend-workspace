flowchart LR
    CAP(["Admin Cancellation"])
    EP["POST /orders/:id/cancel<br/>(?confirm=)"]
    PREVIEW["preview (writes nothing)"]
    SVC["OrderCancelService"]
    PT["PaymentTransaction<br/>(FOR UPDATE locks)"]
    INV["releaseForOrder<br/>(inventory reservations)"]
    REFUND["Refund engine (24.9)"]
    AUDIT["AdminAuditLog + Cancelled status"]

    CAP -->|"exposes"| EP
    EP -.->|"no confirm"| PREVIEW
    EP -->|"confirm=true"| SVC
    SVC -->|"locks / cascades"| PT
    SVC -->|"releases"| INV
    SVC -->|"post-commit"| REFUND
    SVC -->|"writes"| AUDIT

    classDef ego fill:#ffe0b2,stroke:#e65100,stroke-width:3px,color:#000;
    classDef neighbor fill:#e3f2fd,stroke:#1565c0,color:#000;
    class CAP ego;
    class EP,PREVIEW,SVC,PT,INV,REFUND,AUDIT neighbor;
