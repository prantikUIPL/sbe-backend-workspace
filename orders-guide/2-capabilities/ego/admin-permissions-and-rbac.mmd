flowchart LR
    CAP(["Admin Order RBAC"])
    GUARD["@Permissions('orders.*')<br/>on 22 admin routes"]
    PERMS["permission.seeder<br/>21 orders.* keys"]
    GROUPS["permission-group.seeder<br/>8 orders groups"]
    ROOT["View Orders<br/>(root group)"]
    ROLE["role.seeder<br/>direct role grant"]
    FLAT["GET /permissions<br/>(flat, is_visible)"]
    GROUPED["GET /roles/:id/permission-groups<br/>(grouped screen)"]

    CAP -->|"enforced by"| GUARD
    GUARD -->|"checks keys from"| PERMS
    PERMS -->|"bundled into"| GROUPS
    GROUPS -->|"all depend_on"| ROOT
    PERMS -->|"granted via"| ROLE
    PERMS -->|"exposed by"| FLAT
    GROUPS -->|"exposed by"| GROUPED

    classDef ego fill:#ffe0b2,stroke:#e65100,stroke-width:3px,color:#000;
    classDef neighbor fill:#e3f2fd,stroke:#1565c0,color:#000;
    class CAP ego;
    class GUARD,PERMS,GROUPS,ROOT,ROLE,FLAT,GROUPED neighbor;
