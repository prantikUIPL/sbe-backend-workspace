erDiagram
    COMPANY                  ||--o{ COMPANY_SUBSCRIPTION : "owned by (cascade)"
    SUBSCRIPTION_PLAN        ||--o{ COMPANY_SUBSCRIPTION : "on plan (restrict)"
    PAYMENT_METHOD           |o--o{ COMPANY_SUBSCRIPTION : "billed via (setNull)"
    COMPANY_SUBSCRIPTION     ||--o{ ORDER : "renews via"
    COMPANY_SUBSCRIPTION     ||--o{ LEAD : "distributes"
    COMPANY_SUBSCRIPTION     ||--o{ RETENTION_OFFER_REDEMPTION : "retained by"
    COMPANY_SUBSCRIPTION     ||--o{ PPL_COMPANY_ACCOUNT_HISTORY : "logged in"

    COMPANY_SUBSCRIPTION {
        int id PK
        int company_id FK "owner"
        int subscription_plan_id FK "plan"
        int payment_method_id FK "nullable; default pm"
        string stripe_subscription_id UK "nullable; webhook lookup"
        string stripe_customer_id "nullable"
        enum status "default active"
        enum billing_frequency "default monthly"
        decimal subscription_amount "nullable; list price"
        decimal total_amount "nullable; paid today"
        decimal price_per_lead_locked "nullable; PAYG snapshot"
        int lead_credits_xxx "allocated / used / rollover / granted"
        datetime current_period_start "nullable"
        datetime current_period_end "nullable"
        boolean cancel_at_period_end "default false"
        datetime canceled_at "nullable"
        string cancellation_reason "nullable; provider free-text"
        datetime paused_at "nullable"
        datetime resumed_at "nullable"
        int daily_leads_delivered "default 0; pacing"
        int weekly_leads_delivered "default 0; pacing"
        datetime daily_reset_at "nullable; pacing reset"
        datetime weekly_reset_at "nullable; pacing reset"
    }
