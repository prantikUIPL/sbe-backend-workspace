    SHOW_PRODUCT {
        int id PK
        int show_id FK "UK with product_id"
        int product_id FK "UK with show_id"
        int quantity "stock"
        enum price_type "price_tier_based | custom_price"
        decimal sales_price "10,2"
        decimal actual_price "10,2; sales <= actual (CHECK)"
        boolean is_visible "default true"
        datetime created_at
        datetime updated_at
    }
